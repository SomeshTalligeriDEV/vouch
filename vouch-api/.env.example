MONGO_URI=mongodb://localhost:27017
MONGO_DB=vouch
REDIS_URL=redis://localhost:6379

# Must be at least 32 characters in production. Generate with: openssl rand -hex 32
JWT_SECRET=change-me-in-production
JWT_REFRESH_SECRET=change-me-too-in-production

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URL=http://localhost:3000/auth/callback

STRIPE_CLIENT_ID=
STRIPE_SECRET_KEY=

RESEND_API_KEY=
EMAIL_FROM=Vouch <noreply@vouch.dev>

R2_BUCKET=
R2_ACCESS_KEY=
R2_SECRET_KEY=
R2_ENDPOINT=
# Public base URL objects are served from (bucket public domain or CDN).
# Falls back to R2_ENDPOINT/R2_BUCKET if unset.
R2_PUBLIC_URL=

SENTRY_DSN=

# Frontend base URL, used in email links.
APP_URL=http://localhost:3000

# Comma-separated origins allowed to make cross-origin requests.
# In development defaults to * if unset. Set explicitly in production.
# Example: ALLOWED_ORIGINS=https://vouch.dev,https://www.vouch.dev
ALLOWED_ORIGINS=

PORT=8080
ENV=development
