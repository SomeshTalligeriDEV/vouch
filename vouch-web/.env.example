# ── Vouch Web — environment variables ──────────────────────────────────────
# Copy this file to .env.local and fill in your values.
# Do NOT commit .env.local — it is gitignored.

# Backend API base URL (no trailing slash)
NEXT_PUBLIC_API_URL=http://localhost:8080/api/v1

# Canonical frontend URL (used for OG / SEO)
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# GitHub OAuth App client ID (public — used for the OAuth redirect link)
NEXT_PUBLIC_GITHUB_CLIENT_ID=your_github_client_id_here

# Sentry DSN (optional — leave empty to disable error reporting)
NEXT_PUBLIC_SENTRY_DSN=

# PostHog / analytics key (optional)
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com
